<idea-plugin require-restart="true">
  <id>com.jetbrains.rider.plugins.sonarwhale</id>
  <name>Sonarwhale</name>
  <version>_PLACEHOLDER_</version>
  <vendor email="" url="">Yannik Köllmann</vendor>
  <idea-version since-build="_PLACEHOLDER_" until-build="_PLACEHOLDER_" />

  <depends>com.intellij.modules.platform</depends>

  <description>
<![CDATA[
<p><b>Sonarwhale</b> reads your API endpoints from OpenAPI/Swagger sources and makes them testable directly inside Rider.</p>
<ul>
  <li>Automatic endpoint discovery via OpenAPI/Swagger — no build required</li>
  <li>Supports Server URL (auto-discovery), local file, or static import</li>
  <li>Live updates on file changes and configurable refresh</li>
  <li>Built-in HTTP client with request builder, params editor, and body editor</li>
  <li>Multiple environments (dev / staging / prod)</li>
  <li>Saved requests per endpoint</li>
  <li>Postman Collection export</li>
</ul>
]]>
  </description>

  <extensions defaultExtensionNs="com.intellij">

    <!-- Tool window shown at the bottom of Rider -->
    <toolWindow
        id="Sonarwhale"
        anchor="bottom"
        secondary="false"
        icon="/icons/sonarwhale.svg"
        factoryClass="com.sonarwhale.toolwindow.SonarwhaleToolWindowFactory"/>

    <!-- Trigger initial OpenAPI fetch after project opens -->
    <postStartupActivity implementation="com.sonarwhale.SonarwhaleStartupActivity"/>

    <!-- Notification group for silent gutter-icon request results -->
    <notificationGroup id="Sonarwhale" displayType="BALLOON" isLogByDefault="false"/>

    <!-- Settings pages under Tools > Sonarwhale -->
    <projectConfigurable
        parentId="tools"
        instance="com.sonarwhale.settings.SonarwhaleConfigurable"
        displayName="Sonarwhale"
        id="com.sonarwhale.settings.SonarwhaleConfigurable"
        nonDefaultProject="false"/>
    <projectConfigurable
        parentId="com.sonarwhale.settings.SonarwhaleConfigurable"
        instance="com.sonarwhale.settings.SonarwhaleSourcesConfigurable"
        displayName="Sources"
        nonDefaultProject="false"/>

  </extensions>

  <actions>
    <action id="Sonarwhale.OpenInSonarwhale"
            class="com.sonarwhale.actions.OpenInSonarwhaleAction"
            text="Open in Sonarwhale"
            description="Jump to this endpoint in the Sonarwhale tool window">
      <add-to-group group-id="EditorPopupMenu" anchor="last"/>
    </action>
  </actions>

</idea-plugin>
