<idea-plugin require-restart="true">
  <id>com.jetbrains.rider.plugins.routex</id>
  <name>Routex</name>
  <version>_PLACEHOLDER_</version>
  <vendor email="" url="">Yannik Köllmann</vendor>
  <idea-version since-build="_PLACEHOLDER_" until-build="_PLACEHOLDER_" />

  <depends>com.intellij.modules.rider</depends>

  <description>
<![CDATA[
<p><b>Routex</b> reads your API endpoints from OpenAPI/Swagger sources and makes them testable directly inside Rider.</p>
<ul>
  <li>Automatic endpoint discovery via OpenAPI/Swagger — no build required</li>
  <li>Supports Server URL (auto-discovery), local file, or static import</li>
  <li>Live updates on file changes and configurable refresh</li>
  <li>Built-in HTTP client with request builder, params editor, and body editor</li>
  <li>Multiple environments (dev / staging / prod)</li>
  <li>Saved requests per endpoint</li>
  <li>Postman Collection export</li>
</ul>
]]>
  </description>

  <extensions defaultExtensionNs="com.intellij">

    <!-- Tool window shown at the bottom of Rider -->
    <toolWindow
        id="RouteX"
        anchor="bottom"
        secondary="false"
        icon="/icons/routex.svg"
        factoryClass="com.routex.toolwindow.RouteXToolWindowFactory"/>

    <!-- Project-level service: holds the endpoint list, triggers OpenAPI fetches -->
    <projectService serviceImplementation="com.routex.service.RouteIndexService"/>

    <!-- Project-level service: manages environments and OpenAPI cache -->
    <projectService serviceImplementation="com.routex.service.EnvironmentService"/>

    <!-- Project-level service: persists base URL, saved requests, and param values -->
    <projectService serviceImplementation="com.routex.RouteXStateService"/>

    <!-- Project-level service: renders gutter play-icons on C# endpoint methods (Phase 4) -->
    <projectService serviceImplementation="com.routex.gutter.RouteXGutterService"/>

    <!-- Trigger initial OpenAPI fetch after project opens -->
    <postStartupActivity implementation="com.routex.RouteXStartupActivity"/>

  </extensions>

  <actions>
    <action id="Routex.OpenInRouteX"
            class="com.routex.actions.OpenInRouteXAction"
            text="Open in RouteX"
            description="Jump to this endpoint in the RouteX tool window">
      <add-to-group group-id="EditorPopupMenu" anchor="last"/>
    </action>
  </actions>

</idea-plugin>
